{
  "expo": {
    "name": "project-planner",
    "slug": "projectplanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "projectplanner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font"
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "APIKEY": "AIzaSyDAjBm0oiWHEOPSZNzZs2OPqQNp4hmR8AU",
      "AUTHDOMAIN": "project-planner-lisa.firebaseapp.com",
      "PROJECTID": "project-planner-lisa",
      "STORAGEBUCKET": "project-planner-lisa.firebasestorage.app",
      "MESSAGINGSENDERID": "197964480827",
      "APPID": "1:197964480827:web:fe57819fed6ffd5929b71e",
      "router": {},
      "eas": {
        "projectId": "7793c840-a941-433f-96d0-09ad21569d0a"
      }
    },
    "owner": "lisa.vercruysse"
  }
}
